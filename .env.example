# AWS Configuration
AWS_DEFAULT_REGION=us-east-1
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:cost-optimization-alerts
S3_BUCKET_NAME=aws-cost-optimization-reports-123456789012

# Thresholds
EC2_CPU_THRESHOLD=5.0
EC2_IDLE_HOURS=72
RDS_CONNECTION_THRESHOLD=0
RDS_IDLE_HOURS=48
K8S_REQUESTS_THRESHOLD=0
K8S_IDLE_HOURS=24

# Execution mode
# Set to 'true' to dry-run (detect resources and generate reports without stopping or scaling resources)
DRY_RUN=true

# Kubernetes config path (optional, falls back to in-cluster config if not set)
# KUBECONFIG=~/.kube/config
